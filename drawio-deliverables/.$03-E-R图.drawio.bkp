        <mxCell id="r1" value="1 : N&lt;br/&gt;一个用户可拥有多个会话" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=13;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="appUser" target="appSession"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r2" value="1 : N&lt;br/&gt;一个用户可发起多个诊断任务" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=13;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="appUser" target="diagnosisTask"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r3" value="1 : N&lt;br/&gt;一个用户可拥有多条诊断记录" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=13;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="appUser" target="diagnosisRecord"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r4" value="0..1 : 1&lt;br/&gt;任务完成后关联一条最终记录" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=13;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="diagnosisTask" target="diagnosisRecord"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r5" value="1 : N&lt;br/&gt;一条诊断记录可收到多条反馈" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=13;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="diagnosisRecord" target="feedbackRecord"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r6" value="1 : N&lt;br/&gt;一个用户可产生多条事件记录" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=13;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="appUser" target="eventRecord"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r7" value="0..1 : N&lt;br/&gt;事件可关联某条诊断记录" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=13;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="diagnosisRecord" target="eventRecord"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="note1" value="&lt;b&gt;建模说明&lt;/b&gt;&lt;br/&gt;1. diagnosis_task 表示“执行过程”&lt;br/&gt;2. diagnosis_record 表示“最终结果”&lt;br/&gt;3. ai_feedback_record 与 event_record 用于审计与优化&lt;br/&gt;4. 图中按业务语义表达关系，数据库脚本未显式声明外键" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="760" y="560" width="280" height="170" as="geometry" /></mxCell>
