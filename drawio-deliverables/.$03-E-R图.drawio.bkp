        <mxCell id="diagnosisTask" value="&lt;b&gt;diagnosis_task&lt;/b&gt;&lt;hr/&gt;PK task_id&lt;br/&gt;record_id&lt;br/&gt;user_id&lt;br/&gt;username&lt;br/&gt;role&lt;br/&gt;status&lt;br/&gt;progress&lt;br/&gt;stage_message&lt;br/&gt;input_image_*&lt;br/&gt;subject_scope&lt;br/&gt;is_socratic&lt;br/&gt;vision_model&lt;br/&gt;reasoning_model&lt;br/&gt;vision_result_json&lt;br/&gt;partial_result_json&lt;br/&gt;final_result_json&lt;br/&gt;error_message&lt;br/&gt;created_at / started_at / updated_at / finished_at" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="770" y="120" width="300" height="360" as="geometry" /></mxCell>
