  <diagram id="copilot-db-design" name="数据库设计图">
    <mxGraphModel dx="1700" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;font style=&quot;font-size:24px;&quot;&gt;&lt;b&gt;Solvian（Copilot）数据库设计图&lt;/b&gt;&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1"><mxGeometry x="710" y="20" width="520" height="40" as="geometry" /></mxCell>
        <mxCell id="subtitle" value="主键 / 唯一约束 / 索引 / 逻辑外键语义 / JSON-TEXT 字段分布" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="650" y="60" width="640" height="30" as="geometry" /></mxCell>

        <mxCell id="userTbl" value="&lt;b&gt;app_user&lt;/b&gt;&lt;hr/&gt;&lt;b&gt;PK&lt;/b&gt; id : BIGSERIAL&lt;br/&gt;&lt;b&gt;UK&lt;/b&gt; user_id : VARCHAR(64)&lt;br/&gt;&lt;b&gt;UK&lt;/b&gt; username : VARCHAR(64)&lt;br/&gt;password : VARCHAR(255)&lt;br/&gt;role : VARCHAR(20) CHECK&lt;br/&gt;created_at : TIMESTAMPTZ&lt;br/&gt;updated_at : TIMESTAMPTZ&lt;hr/&gt;&lt;b&gt;Index&lt;/b&gt; idx_app_user_role(role)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="70" y="150" width="280" height="240" as="geometry" /></mxCell>
        <mxCell id="sessionTbl" value="&lt;b&gt;app_session&lt;/b&gt;&lt;hr/&gt;&lt;b&gt;PK&lt;/b&gt; token : VARCHAR(128)&lt;br/&gt;user_id : VARCHAR(64)&lt;br/&gt;username : VARCHAR(64)&lt;br/&gt;role : VARCHAR(20)&lt;br/&gt;created_at : TIMESTAMPTZ&lt;hr/&gt;&lt;b&gt;Index&lt;/b&gt; idx_app_session_user_id(user_id)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="400" y="150" width="260" height="190" as="geometry" /></mxCell>
        <mxCell id="recordTbl" value="&lt;b&gt;diagnosis_record&lt;/b&gt;&lt;hr/&gt;&lt;b&gt;PK&lt;/b&gt; record_id : VARCHAR(64)&lt;br/&gt;user_id / username / role&lt;br/&gt;status : VARCHAR(32)&lt;br/&gt;steps_json : TEXT&lt;br/&gt;feedback : TEXT&lt;br/&gt;error_index : INTEGER&lt;br/&gt;tags_json : TEXT&lt;br/&gt;is_socratic : BOOLEAN&lt;br/&gt;problem_type : VARCHAR(64)&lt;br/&gt;image_name : VARCHAR(255)&lt;br/&gt;ai_feedback : VARCHAR(32)&lt;br/&gt;error_type : VARCHAR(32)&lt;br/&gt;note : TEXT&lt;br/&gt;math_data_json : TEXT&lt;br/&gt;created_at : TIMESTAMPTZ&lt;hr/&gt;&lt;b&gt;Index&lt;/b&gt; idx_diagnosis_user_id(user_id)&lt;br/&gt;&lt;b&gt;Index&lt;/b&gt; idx_diagnosis_created_at(created_at DESC)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="710" y="120" width="330" height="370" as="geometry" /></mxCell>
        <mxCell id="taskTbl" value="&lt;b&gt;diagnosis_task&lt;/b&gt;&lt;hr/&gt;&lt;b&gt;PK&lt;/b&gt; task_id : VARCHAR(64)&lt;br/&gt;record_id : VARCHAR(64)&lt;br/&gt;user_id / username / role&lt;br/&gt;status : VARCHAR(32)&lt;br/&gt;progress : INTEGER&lt;br/&gt;stage_message : VARCHAR(255)&lt;br/&gt;input_image_name : VARCHAR(255)&lt;br/&gt;input_image_path : VARCHAR(512)&lt;br/&gt;input_image_hash : VARCHAR(128)&lt;br/&gt;input_content_type : VARCHAR(128)&lt;br/&gt;input_file_size : BIGINT&lt;br/&gt;subject_scope : VARCHAR(64)&lt;br/&gt;is_socratic : BOOLEAN&lt;br/&gt;vision_model / reasoning_model&lt;br/&gt;vision_result_json : TEXT&lt;br/&gt;partial_result_json : TEXT&lt;br/&gt;final_result_json : TEXT&lt;br/&gt;error_message : TEXT&lt;br/&gt;created_at / started_at / updated_at / finished_at&lt;hr/&gt;&lt;b&gt;Index&lt;/b&gt; idx_diagnosis_task_user_id(user_id)&lt;br/&gt;&lt;b&gt;Index&lt;/b&gt; idx_diagnosis_task_status(status)&lt;br/&gt;&lt;b&gt;Index&lt;/b&gt; idx_diagnosis_task_hash(input_image_hash)&lt;br/&gt;&lt;b&gt;Index&lt;/b&gt; idx_diagnosis_task_created_at(created_at DESC)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="1090" y="90" width="360" height="520" as="geometry" /></mxCell>
        <mxCell id="feedbackTbl" value="&lt;b&gt;ai_feedback_record&lt;/b&gt;&lt;hr/&gt;&lt;b&gt;PK&lt;/b&gt; id : BIGSERIAL&lt;br/&gt;&lt;b&gt;UK&lt;/b&gt; feedback_id : VARCHAR(64)&lt;br/&gt;record_id : VARCHAR(64)&lt;br/&gt;user_id / username / role&lt;br/&gt;ai_feedback : VARCHAR(32)&lt;br/&gt;error_type : VARCHAR(32)&lt;br/&gt;note : TEXT&lt;br/&gt;created_at : TIMESTAMPTZ&lt;hr/&gt;&lt;b&gt;Index&lt;/b&gt; idx_ai_feedback_record_id(record_id)&lt;br/&gt;&lt;b&gt;Index&lt;/b&gt; idx_ai_feedback_created_at(created_at DESC)&lt;br/&gt;&lt;b&gt;Index&lt;/b&gt; uk_ai_feedback_feedback_id(feedback_id)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="710" y="590" width="330" height="260" as="geometry" /></mxCell>
        <mxCell id="eventTbl" value="&lt;b&gt;event_record&lt;/b&gt;&lt;hr/&gt;&lt;b&gt;PK&lt;/b&gt; id : BIGSERIAL&lt;br/&gt;&lt;b&gt;UK&lt;/b&gt; event_id : VARCHAR(64)&lt;br/&gt;user_id / username / role&lt;br/&gt;event_name : VARCHAR(128)&lt;br/&gt;event_type : VARCHAR(128)&lt;br/&gt;page : VARCHAR(255)&lt;br/&gt;action : VARCHAR(255)&lt;br/&gt;record_id : VARCHAR(64)&lt;br/&gt;payload_json : TEXT&lt;br/&gt;created_at : TIMESTAMPTZ&lt;hr/&gt;&lt;b&gt;Index&lt;/b&gt; idx_event_created_at(created_at DESC)&lt;br/&gt;&lt;b&gt;Index&lt;/b&gt; uk_event_record_event_id(event_id)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="70" y="500" width="320" height="280" as="geometry" /></mxCell>

        <mxCell id="rel1" value="user_id（逻辑外键）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="userTbl" target="sessionTbl"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rel2" value="user_id（逻辑外键）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="userTbl" target="recordTbl"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rel3" value="user_id（逻辑外键）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="userTbl" target="taskTbl"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rel4" value="record_id（任务结果关联）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="taskTbl" target="recordTbl"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rel5" value="record_id（反馈记录关联）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="recordTbl" target="feedbackTbl"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rel6" value="record_id（事件可选关联）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="recordTbl" target="eventTbl"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="noteJson" value="&lt;b&gt;JSON/TEXT 字段说明&lt;/b&gt;&lt;br/&gt;diagnosis_record.steps_json / tags_json / math_data_json&lt;br/&gt;diagnosis_task.vision_result_json / partial_result_json / final_result_json&lt;br/&gt;event_record.payload_json&lt;br/&gt;&lt;br/&gt;设计意图：以轻量 TEXT 持久化结构化内容，便于快速落地与后续迁移。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1500" y="130" width="320" height="170" as="geometry" /></mxCell>
        <mxCell id="noteIndex" value="&lt;b&gt;索引设计说明&lt;/b&gt;&lt;br/&gt;1. 用户/任务/记录均按 user_id 支撑按用户查询&lt;br/&gt;2. created_at DESC 支撑最近记录和看板场景&lt;br/&gt;3. diagnosis_task.status 支撑轮询与调度&lt;br/&gt;4. diagnosis_task.input_image_hash 支撑视觉结果缓存复用&lt;br/&gt;5. feedback_id / event_id 作为审计唯一标识" style="shape=note;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1500" y="360" width="320" height="210" as="geometry" /></mxCell>
        <mxCell id="noteNoFk" value="&lt;b&gt;约束说明&lt;/b&gt;&lt;br/&gt;SQL 脚本当前未显式声明物理外键，图中关系按业务语义呈现。这样做可降低初始化耦合度，但应用层需保证引用一致性。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1500" y="630" width="320" height="150" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
